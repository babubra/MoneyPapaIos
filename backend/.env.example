# === MonPapa Backend — переменные окружения ===
# Скопируй в .env и заполни значения

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=monpapa
POSTGRES_PASSWORD=monpapa_dev_secret
POSTGRES_DB=monpapa
# Для локальной разработки (без Docker) — localhost
# В Docker — переопределяется через docker-compose.yml
DATABASE_URL=postgresql+asyncpg://monpapa:monpapa_dev_secret@localhost:5432/monpapa

# ── Безопасность (JWT) ───────────────────────────────────────────
# SECRET_KEY обязателен. Генерация: openssl rand -hex 32
# Минимум 32 символа. Не должен начинаться с "change-me".
# Ротация ключа инвалидирует все живые JWT-токены.
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── AiTunnel API (OpenAI-совместимый прокси → Gemini) ────────────
AITUNNEL_API_KEY=your-aitunnel-api-key-here
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1/
AI_MODEL=gemini-3.1-flash-lite-preview

# ── Rate limiting (legacy — не используется после Auth Model C) ──
AI_RATE_LIMIT_DAILY=50
AI_RATE_LIMIT_AUDIO_HOURLY=5
AI_MAX_TEXT_LENGTH=500
AI_MAX_AUDIO_SECONDS=30
# Лимит размера аудио-файла на /parse-audio (мегабайты).
AI_MAX_AUDIO_SIZE_MB=5

# ── Auth Model C ────────────────────────────────────────────────
# AI trial — сколько бесплатных запросов получает каждый user (lifetime).
AI_TRIAL_LIMIT=50
# Bundle ID iOS-приложения (audience для Apple identity_token).
APPLE_BUNDLE_ID=fatau.Monpapa

# ── Auto-learn mappings caps (см. C1.5 в todo/audit/C1_C2_ai_layer.md) ──
# Сколько маппингов из БД попадает в AI-prompt (топ-N по weight).
AI_MAPPINGS_PROMPT_LIMIT=30
# Общий cap маппингов на user; превышение удаляется в /mapping upsert.
AI_MAPPINGS_TOTAL_LIMIT=200

# ── SMTP (Magic Link) ───────────────────────────────────────────
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your@domain.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM=your@domain.com

# ── Авторизация ──────────────────────────────────────────────────
# Белый список email (через запятую). Пусто = все разрешены.
ALLOWED_EMAILS=
# DEV_MODE=true → автологин без отправки писем.
# Разрешён только на localhost; для запуска в Docker/CI на не-localhost
# нужно явно поставить DEV_HOST_OK=true.
DEV_MODE=false
DEV_HOST_OK=false

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Magic-link base URL ─────────────────────────────────────────
# Базовый URL приложения, который вшивается в magic-link письма.
# В проде ОБЯЗАТЕЛЬНО выставить публичный домен — иначе атакующий через
# Host-заголовок может подменить URL и забрать magic_token жертвы.
BASE_URL=http://localhost:8001
