# === MonPapa Backend — переменные окружения ===
# Скопируй в .env и заполни значения

# Секретный ключ для подписи JWT (минимум 32 символа)
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# Срок жизни токена в минутах (по умолчанию 30 дней)
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# AiTunnel API (OpenAI-совместимый прокси → Gemini)
AITUNNEL_API_KEY=your-aitunnel-api-key-here
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1/

# Модель (передаётся в model= при запросе)
AI_MODEL=gemini-3.1-flash-lite-preview

# База данных (SQLite по умолчанию, для prod — PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./monpapa.db

# Rate limiting
AI_RATE_LIMIT_DAILY=50
AI_RATE_LIMIT_AUDIO_HOURLY=5
AI_MAX_TEXT_LENGTH=500
AI_MAX_AUDIO_SECONDS=30

# Разрешённые origins для CORS (через запятую)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
